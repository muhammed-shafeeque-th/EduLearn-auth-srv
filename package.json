{
  "name": "auth",
  "version": "1.0.0",
  "description": "EduLearn auth service",
  "main": "index.ts",
  "author": "muhammed shafeeque",
  "license": "MIT",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --require tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "proto:gen": "npx protoc --plugin=protoc-gen-ts_proto=\"D:\\Edulearn\\api-gateway\\node_modules\\.bin\\protoc-gen-ts_proto.cmd\" --ts_proto_out=./src/infrastructure/gRPC/generated --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true -I ./proto ./proto/*.proto",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "clean": "rimraf dist",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "prettier . --ext .js,.jsx,.ts,.tsx --check",
    "prettier:fix": "npm run prettier -- --write",
    "format": "npm run prettier:fix && npm run lint:fix"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.0",
    "@grpc/proto-loader": "^0.7.13",
    "@kafkajs/confluent-schema-registry": "^3.9.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.59.0",
    "@opentelemetry/sdk-metrics": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.201.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.5.0",
    "google-auth-library": "^10.3.0",
    "google-protobuf": "^3.21.4",
    "handlebars": "^4.7.8",
    "inversify": "^7.0.1",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "node-cron": "^4.0.5",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.21",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-loki": "^6.1.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cookie-session": "^2.0.49",
    "@types/google-protobuf": "^3.15.12",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "ts-proto": "^2.6.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.8.2"
  }
}
